<Window x:Class="DeathAdderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeathAdderManager.ViewModels"
        xmlns:local="clr-namespace:DeathAdderManager"
        Title="Razer Synapse Offline"
        Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#151515"
        FontFamily="{StaticResource MainFont}"
        Foreground="{StaticResource TextPrimBrush}">

    <Window.Resources>
        <!-- Synapse App Tab Style -->
        <Style TargetType="local:NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Padding" Value="15,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:NavButton">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                            <TextBlock Text="{TemplateBinding Label}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="{TemplateBinding Padding}" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter Property="Foreground" Value="Black"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>   <!-- Top App Level Tabs -->
            <RowDefinition Height="50"/>   <!-- Device specific Nav -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Bottom Status Bar -->
        </Grid.RowDefinitions>

        <!-- ── Top App Bar ── -->
        <Grid Grid.Row="0" Background="#151515">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" Foreground="#333333" FontSize="14" Margin="0,0,15,0"/>
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="14" Cursor="Hand"/>
            </StackPanel>
            
            <TextBlock Text="RAZER DEATHADDER ESSENTIAL" Foreground="{StaticResource TextSecBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Device Level Sub-Nav Bar ── -->
        <Border Grid.Row="1" Background="#1B1B1B" BorderBrush="#222222" BorderThickness="0,0,0,1">
            <Grid>
                <!-- Profile dropdown -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="200" Background="#151515" BorderBrush="#333333" BorderThickness="1" Foreground="{StaticResource TextPrimBrush}" SelectedIndex="0">
                        <ComboBoxItem>DESKTOP-QHJNS53-Default</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0" Cursor="Hand"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <local:NavButton Label="CUSTOMIZE"   TabIndex="1" GroupName="NavTabs" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"/>
                    <local:NavButton Label="PERFORMANCE" TabIndex="0" GroupName="NavTabs" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"/>
                    <local:NavButton Label="LIGHTING"    TabIndex="2" GroupName="NavTabs" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main Content Area ── -->
        <Grid Grid.Row="2" Background="#151515">
            <local:PerformancePage  Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TabVis}, ConverterParameter=0}" DataContext="{Binding PerformanceVm}"/>
            <local:ButtonsPage      Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TabVis}, ConverterParameter=1}" DataContext="{Binding ButtonsVm}"/>
            <local:LightingPage     Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TabVis}, ConverterParameter=2}" DataContext="{Binding LightingVm}"/>
            <local:ProfilesPage     Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TabVis}, ConverterParameter=3}" DataContext="{Binding ProfilesVm}"/>
            <local:SettingsPage     Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TabVis}, ConverterParameter=4}" DataContext="{Binding SettingsVm}"/>
        </Grid>

        <!-- ── Bottom Status Bar ── -->
        <Border Grid.Row="3" Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0" Padding="15,5">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock FontSize="12" FontFamily="Consolas" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="{Binding DeviceStatus, StringFormat='{}Connected to {0}'}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Text"       Value="Disconnected - No device detected"/>
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="(Offline Mode - 0% Background Usage)" Foreground="{StaticResource TextSecBrush}" FontSize="11" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
