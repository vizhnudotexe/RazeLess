<UserControl x:Class="DeathAdderManager.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeepBrush}">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Profiles" Style="{StaticResource SectionHeading}" FontSize="20"/>

            <!-- Profile list -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Saved Profiles" Style="{StaticResource SectionHeading}"/>
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"  Value="Transparent"/>
                                <Setter Property="Foreground"  Value="{StaticResource TextPrimBrush}"/>
                                <Setter Property="Padding"     Value="12,8"/>
                                <Setter Property="Margin"      Value="0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bg" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#002A15"/>
                                                    <Setter TargetName="Bg" Property="BorderBrush"  Value="{StaticResource AccentBrush}"/>
                                                    <Setter TargetName="Bg" Property="BorderThickness"  Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgPanelBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 " FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Switch to Selected" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SwitchProfileCommand}" Margin="0,0,8,0"/>
                        <Button Content="Delete" Style="{StaticResource DangerBtn}"
                                Command="{Binding DeleteProfileCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,8,0,0"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>

            <!-- Create new profile -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Create New Profile" Style="{StaticResource SectionHeading}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="220" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,10,0"/>
                        <Button Content="Create" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding CreateProfileCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
