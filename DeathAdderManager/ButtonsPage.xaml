<UserControl x:Class="DeathAdderManager.ButtonsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DeathAdderManager.ViewModels"
             xmlns:local="clr-namespace:DeathAdderManager"
             Background="#151515">
    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisLocal"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisLocal"/>
        
        <!-- Style for remappable labels -->
        <Style x:Key="ButtonLabel" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer Padding="40" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Mouse Wireframe Layout Container -->
                <Grid Height="450" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Center Placeholder for image -->
                    <Border Grid.Column="1" Grid.RowSpan="5" Background="Transparent" 
                            BorderThickness="1" BorderBrush="#333333" CornerRadius="8" Margin="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="120" Foreground="#2A2A2A" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Mouse Image" Foreground="#2A2A2A" FontSize="16" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Left Buttons Labels -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,50,0,25">
                        <TextBlock Text="Left Click" Foreground="#333333" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,20,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="0" Grid.Row="1" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Right" Margin="0,25,0,25"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Scroll Click">
                        <TextBlock Text="Scroll Click" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>

                    <Button Grid.Column="0" Grid.Row="3" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Right" Margin="0,25,0,25"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Side Button 2 (Forward)">
                        <TextBlock Text="Mouse Button 5" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>

                    <Button Grid.Column="0" Grid.Row="2" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Right" Margin="0,25,0,25"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Side Button 1 (Back)">
                        <TextBlock Text="Mouse Button 4" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>
                    
                    <!-- Right Buttons Labels -->
                    <Button Grid.Column="2" Grid.Row="0" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Left" Margin="20,30,0,40"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Right Click">
                        <TextBlock Text="Right Click" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>

                    <Button Grid.Column="2" Grid.Row="1" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Left" Margin="20,15,0,25"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Scroll Up">
                        <TextBlock Text="Scroll Up" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>

                    <Button Grid.Column="2" Grid.Row="2" Style="{StaticResource ButtonLabel}" HorizontalAlignment="Left" Margin="20,25,0,25"
                            Command="{Binding SelectButtonCommand}" CommandParameter="Scroll Down">
                        <TextBlock Text="Scroll Down" Foreground="{StaticResource TextPrimBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Button>
                    
                    <!-- Dotted lines background overlay -->
                    <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.RowSpan="5" IsHitTestVisible="False">
                        <Line X1="320" Y1="60" X2="450" Y2="120" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                        <Line X1="320" Y1="140" X2="480" Y2="160" Stroke="#444444" StrokeThickness="1.5" />
                        <Line X1="320" Y1="220" X2="450" Y2="240" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                        <Line X1="320" Y1="300" X2="450" Y2="280" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                        
                        <Line X1="700" Y1="40" X2="560" Y2="120" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                        <Line X1="700" Y1="110" X2="540" Y2="140" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                        <Line X1="700" Y1="200" X2="540" Y2="180" Stroke="#444444" StrokeThickness="1" StrokeDashArray="2 2" />
                    </Grid>
                </Grid>
                
                <Border Style="{StaticResource UnsavedBadge}" Margin="0,20,0,0" HorizontalAlignment="Left" 
                        Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisLocal}, ConverterParameter=True}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ You have unsaved changes" FontSize="13" Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="APPLY" Style="{StaticResource PrimaryBtn}" Command="{Binding ApplyCommand}" Padding="15,6" FontSize="11"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Sidebar Customization Panel UI -->
        <Grid Width="340" HorizontalAlignment="Left" Background="#1B1B1B" 
              Visibility="{Binding SelectedRow, Converter={StaticResource NullToVisLocal}}">
            <Border BorderBrush="#333333" BorderThickness="0,0,1,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Background="#151515">
                    <Border Height="40" Padding="10">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Height="40" Padding="10">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Height="40" BorderThickness="3,0,0,0" BorderBrush="{StaticResource AccentBrush}">
                        <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <Grid Margin="15,0">
                            <TextBlock Text="{Binding SelectedRow.ButtonName}" Foreground="{StaticResource TextSecBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button Command="{Binding CloseSelectionCommand}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecBrush}" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="20">
                        <TextBlock Text="MOUSE FUNCTION" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        
                        <Border BorderBrush="#333333" BorderThickness="1" Background="Black">
                            <StackPanel>
                                <Grid Height="30" Margin="10,0">
                                    <TextBlock Text="{Binding SelectedRow.CurrentAction}" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE011;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0">
                                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding AvailableActions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.ApplyActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,8">
                                                        <TextBlock Text="{Binding}">
                                                            <TextBlock.Foreground>
                                                                <MultiBinding Converter="{StaticResource SelectedActionToBrush}">
                                                                    <Binding Path="."/>
                                                                    <Binding Path="DataContext.SelectedRow.CurrentAction" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </TextBlock.Foreground>
                                                        </TextBlock>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
